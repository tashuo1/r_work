APP_HOST=127.0.0.1
APP_PORT=9000

# 默认使用本地 H2 文件库，适合首次拉取后直接演示。
ONTOLOGY_DB_URL=jdbc:h2:file:./ontology-lite/runtime-data/ontology-platform;MODE=MySQL;DATABASE_TO_UPPER=false;AUTO_SERVER=TRUE
ONTOLOGY_DB_DRIVER=org.h2.Driver
ONTOLOGY_DB_USERNAME=sa
ONTOLOGY_DB_PASSWORD=

# 如需连接 MySQL/PolarDB，请复制本文件为 ontology-platform.env 后按需修改。
# ONTOLOGY_DB_URL=jdbc:mysql://127.0.0.1:3306/ontology_meta?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
# ONTOLOGY_DB_DRIVER=com.mysql.cj.jdbc.Driver
# ONTOLOGY_DB_USERNAME=root
# ONTOLOGY_DB_PASSWORD=your_password
